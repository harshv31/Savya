# Savya — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
#
# The site runs fully without any of these set (imagery falls back to local
# files + curated photography). They are placeholders for the planned
# Shopify / CMS / consultation-form integrations.

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://savya.com"

# --- Shopify (Storefront API) — optional, for live commerce ---
# SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=""

# --- Headless CMS (e.g. Sanity / Contentful) — optional, for the Journal ---
# CMS_PROJECT_ID=""
# CMS_API_TOKEN=""

# --- Consultation form / email (e.g. Resend) — optional ---
# RESEND_API_KEY=""
# CONTACT_TO_EMAIL="studio@savya.com"

# --- Instagram feed (Meta Graph API) — optional ---
# INSTAGRAM_ACCESS_TOKEN=""
